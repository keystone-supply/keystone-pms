{
  "name": "keystone-pms",
  "version": "0.1.0",
  "description": "Keystone PMS – project management for fabrication shop: projects, quotes, P&L, weight calculator, OneDrive integration",
  "repository": {
    "type": "git",
    "url": "https://github.com/keystone-supply/keystone-pms.git"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:tv": "cross-env HOST=0.0.0.0 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "supabase:preflight": "node scripts/security/check-supabase-cli-version.mjs && node scripts/security/check-supabase-linked-preflight.mjs",
    "supabase:migration:new": "node scripts/supabase/create-migration-safe.mjs",
    "supabase:migration:list:linked": "npm run supabase:preflight && ./node_modules/.bin/supabase --agent no migration list --linked --workdir .",
    "supabase:db:push:linked": "npm run supabase:preflight && ./node_modules/.bin/supabase --agent no db push --linked --include-all --yes --workdir .",
    "db:push": "npm run supabase:db:push:linked",
    "import:book1": "npx tsx scripts/import-book1.ts",
    "nest:estimate-payload": "node scripts/estimate-nest-payload-size.mjs",
    "test:sales-board": "node --import tsx --test lib/salesBoard.test.ts",
    "test:project-financials": "node --import tsx --test lib/projectFinancials.test.ts",
    "test:quote-financials-snapshot": "node --import tsx --test lib/quoteFinancialsSnapshot.test.ts",
    "test:project-document-totals": "node --import tsx --test lib/projectDocumentTotalsPolicy.test.ts",
    "test:project-lifecycle": "node --import tsx --test lib/projectTypes.lifecycle.test.ts",
    "test:document-milestones": "node --import tsx --test lib/documentMilestones.test.ts",
    "test:document-pdf": "node --import tsx --test lib/documents/buildProjectDocumentPdf.test.ts",
    "test:rbac-roles": "node --import tsx --test lib/auth/roles.test.ts",
    "test:rbac-sql": "node --env-file=.env.local --import tsx scripts/verify-rbac-sql.ts",
    "test:rbac-api-guards": "node --env-file=.env.local --import tsx scripts/verify-rbac-api-guards.ts",
    "files:index-active": "npx tsx scripts/index-active-projects.ts",
    "test:nest-dual-lane": "npx tsx scripts/verify-nest-dual-lane.ts",
    "test:nest-dxf-export": "npx tsx scripts/verify-nest-dxf-export.ts",
    "sheet-previews:repair": "node --import tsx scripts/run-sheet-preview-repair.ts",
    "security:blocked-deps": "node scripts/security/check-blocked-packages.mjs",
    "security:db-schema-guard": "node scripts/security/check-db-schema-guard.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/msal-node": "^5.0.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.99.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dxf": "^5.3.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "mathjs": "^15.1.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-pdf": "^10.4.1",
    "shadcn": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "csv-parse": "^6.2.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "supabase": "^2.90.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
