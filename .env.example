# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Azure AD (for sign-in and Microsoft Graph / OneDrive)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
# Optional dedicated OneDrive service-account refresh token flow.
# When ONEDRIVE_SERVICE_REFRESH_TOKEN is set, server APIs prefer that token
# and fall back to the signed-in user's Graph token only if refresh fails.
ONEDRIVE_SERVICE_REFRESH_TOKEN=
# Optional overrides; defaults to AZURE_AD_* when omitted.
ONEDRIVE_SERVICE_CLIENT_ID=
ONEDRIVE_SERVICE_CLIENT_SECRET=
ONEDRIVE_SERVICE_TENANT_ID=
# One-time admin-only helper key for capturing refresh token from current
# Azure session via POST /api/auth/onedrive-service-refresh-token-once.
# Set temporarily, use once, then remove.
ONEDRIVE_REFRESH_CAPTURE_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only: CSV import script (`npm run import:book1`), never expose to client
SUPABASE_SERVICE_ROLE_KEY=
# Required for NextAuth -> Supabase authenticated session bridge JWT signing
SUPABASE_JWT_SECRET=
# Optional override (seconds), default is 600
SUPABASE_BRIDGE_TOKEN_TTL_SECONDS=600

# NestNow (local server for nesting) — used by Next.js POST /api/nest only.
# Does not apply when the browser uses Direct NestNow (localhost) from the Nest tab.
# If /api/nest is cut off around ~60s in production, raise reverse-proxy read timeout or use direct mode.
NESTNOW_URL=http://127.0.0.1:3001
